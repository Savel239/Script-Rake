local function GetTool(name)
    local p = game:GetService("Players").LocalPlayer
    return p.Backpack:FindFirstChild(name) or (p.Character and p.Character:FindFirstChild(name))
end

-- Функция огромных кнопок атак
local function CreateAttack(displayName, realToolName)
    local f = Instance.new("Frame", ScrollFrame)
    f.Size = UDim2.new(0, 340, 0, 70)
    f.BackgroundTransparency = 1
    
    local m = Instance.new("TextButton", f)
    m.Size = UDim2.new(0, 240, 1, 0)
    m.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
    m.Text = displayName
    m.Font = Enum.Font.GothamBlack
    m.TextSize = 18
    m.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", m)

    local a = Instance.new("TextButton", f)
    a.Position = UDim2.new(0, 250, 0, 0)
    a.Size = UDim2.new(0, 90, 1, 0)
    a.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    a.Text = "AUTO"
    a.Font = Enum.Font.GothamBlack
    a.TextSize = 16
    a.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", a)

    local on = false
    a.MouseButton1Click:Connect(function()
        on = not on
        a.BackgroundColor3 = on and Color3.fromRGB(0, 255, 200) or Color3.fromRGB(40, 40, 40)
        a.TextColor3 = on and Color3.new(0,0,0) or Color3.new(1,1,1)
    end)

    task.spawn(function()
        while task.wait(0.1) do
            if not ScreenGui.Parent then break end
            local item = GetTool(realToolName)
            m.BackgroundColor3 = item and Color3.fromRGB(0, 180, 70) or Color3.fromRGB(180, 0, 0)
            if on and item and item:FindFirstChild("Remote11") then item.Remote11:FireServer() end
        end
    end)
end

