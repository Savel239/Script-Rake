-- --- ФУНКЦИИ МАГАЗИНА ---
local function Buy(shopType, itemName)
    local args = { [1] = itemName, [2] = 25, [3] = 0, [4] = 0 }
    local guiName = (shopType == "Basic") and "ShopGui" or "SpecialShopGui"
    local remote = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui"):WaitForChild(guiName):WaitForChild("BuyItem")
    remote:FireServer(unpack(args))
end

